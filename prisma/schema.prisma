// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum AccrualScheme {
  MONTHLY
  SEMESTER
  ANNUAL
}

enum LeaveRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum AuditActionType {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  CANCEL
  ADJUSTMENT
  LOGIN
  LOGOUT
}

// User model with role-based access
model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String
  roleId    String
  role      Role       @relation(fields: [roleId], references: [id])
  password  String?
  requiresPasswordChange Boolean @default(false)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relationships
  employees     Employee[]
  leaveRequests LeaveRequest[]
  approvals     LeaveRequest[] @relation("Approver")
  adjustments   BalanceAdjustment[]
  auditLogs     AuditLog[]
  managedEmployees Employee[] @relation("Manager")
}

// Department master data
model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  employees Employee[]

  @@index([code])
}

// Employee profile with department and leave allocation
model Employee {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  designation   String
  managerId     String?
  manager       User?    @relation("Manager", fields: [managerId], references: [id])
  accrualScheme AccrualScheme @default(MONTHLY)
  hireDate      DateTime
  accrualStartDate DateTime?
  gender        Gender?
  employeeNumber String?   @unique
  timeZone      String?    @default("UTC")
  workHoursPerDay Float?   @default(8)
  avatarUrl     String?
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  classificationId String?
  classification   EmployeeClassification? @relation(fields: [classificationId], references: [id])

  // Relationships
  leaveBalances BalanceRecord[]
  leaveRequests LeaveRequest[]
  adjustments   BalanceAdjustment[]
  auditLogs     AuditLog[]

  @@unique([userId])
  @@index([departmentId])
  @@index([classificationId])
}

// Leave types (PTO, Sick Leave, Casual Leave, etc.)
model LeaveType {
  id                  String   @id @default(cuid())
  name                String   @unique
  description         String?
  maxDaysPerYear      Int      // Maximum days allowed per year
  requiresApproval    Boolean  @default(true)
  carryoverAllowed    Boolean  @default(false)
  carryoverMaxDays    Int?     // Maximum days that can be carried over
  carryoverExpiryDays Int?     // Days after which carried over days expire
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relationships
  balanceRecords BalanceRecord[]
  leaveRequests  LeaveRequest[]
  adjustments    BalanceAdjustment[]
  balancePolicies BalancePolicy[]
}

// Leave balance tracking per employee per leave type
model BalanceRecord {
  id                 String   @id @default(cuid())
  employeeId         String
  employee           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId        String
  leaveType          LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  year               Int
  scheme             AccrualScheme
  openingBalance     Float    // Balance at start of period
  accrued            Float    // Total accrued in period
  used               Float    // Total used in period
  adjusted           Float    // Total adjustments (positive or negative)
  closingBalance     Float    // Calculated as openingBalance + accrued - used + adjusted
  carried            Float    // Days carried over from previous period
  lastAccrualDate    DateTime // Last date when accrual was calculated
  nextAccrualDate    DateTime // Next scheduled accrual date
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relationships
  leaveRequests LeaveRequest[]

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
  @@index([leaveTypeId])
}

// Leave requests with approval workflow
model LeaveRequest {
  id              String            @id @default(cuid())
  employeeId      String
  employee        Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId     String
  leaveType       LeaveType         @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  balanceRecordId String
  balanceRecord   BalanceRecord     @relation(fields: [balanceRecordId], references: [id])
  startDate       DateTime
  endDate         DateTime
  durationDays    Float
  reason          String
  status          LeaveRequestStatus @default(DRAFT)
  approvedBy      String?
  approver        User?             @relation("Approver", fields: [approvedBy], references: [id])
  approvalDate    DateTime?
  approvalNotes   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relationships
  auditLogs AuditLog[]

  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([status])
  users User[]
}

// Manual balance adjustments (corrections, bonus, etc.)
model BalanceAdjustment {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId     String
  leaveType       LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  adjustmentType  String   // "correction", "bonus", "compensation", etc.
  adjustmentDays  Float    // Can be negative for deductions
  reason          String
  approvedBy      String
  approver        User     @relation(fields: [approvedBy], references: [id])
  approvalDate    DateTime
  effectiveDate   DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  auditLogs AuditLog[]

  @@index([employeeId])
  @@index([leaveTypeId])
}

// Audit trail for compliance and tracking
model AuditLog {
  id              String            @id @default(cuid())
  actionType      AuditActionType
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  employeeId      String?
  employee        Employee?         @relation(fields: [employeeId], references: [id])
  leaveRequestId  String?
  leaveRequest    LeaveRequest?     @relation(fields: [leaveRequestId], references: [id])
  adjustmentId    String?
  adjustment      BalanceAdjustment? @relation(fields: [adjustmentId], references: [id])
  description     String
  changes         String?           // JSON string with field changes
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime          @default(now())

  @@index([userId])
  @@index([employeeId])
  @@index([actionType])
  @@index([createdAt])
}

// System settings for configuration
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  color       String?
  isSystem    Boolean          @default(false) // System roles cannot be deleted
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  action      String           // e.g., 'CREATE', 'READ', 'UPDATE', 'DELETE', 'APPROVE'
  resource    String           // e.g., 'LEAVE_REQUEST', 'USER', 'ROLE', 'SYSTEM_SETTING'
  description String?
  roles       RolePermission[]
  
  @@unique([action, resource])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// ==========================================
// Holiday Model (LBS-013)
// ==========================================

enum RuleType {
  FIXED_DATE
  NTH_WEEKDAY
  RELATIVE_RULE
  MANUAL_ONLY
}

enum OffsetRule {
  NONE
  NEXT_MONDAY_IF_WEEKEND
  PREV_FRIDAY_IF_WEEKEND
}

model HolidayDefinition {
  id          String       @id @default(cuid())
  name        String
  ruleType    RuleType
  month       Int?
  day         Int?
  weekday     Int?
  nth         Int?
  offsetRule  OffsetRule   @default(NONE)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  occurrences HolidayOccurrence[]
}

model HolidayOccurrence {
  id             String            @id @default(cuid())
  definitionId   String
  definition     HolidayDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  date           DateTime
  observedDate   DateTime
  year           Int
  createdAt      DateTime          @default(now())

  @@unique([definitionId, year])
}

model ManualHoliday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  year        Int
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmployeeClassification {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  active      Boolean    @default(true)
  employees   Employee[]
  balancePolicies BalancePolicy[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model OTP {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      OTPType  @default(FORGOT_PASSWORD)
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, code])
}

enum OTPType {
  FORGOT_PASSWORD
  TWO_FACTOR
  LOGIN
}

model RateLimit {
  id      String   @id @default(cuid())
  key     String   @unique // e.g., "otp:forgot-password:user@example.com"
  points  Int      @default(0)
  lastHit DateTime @default(now())
  resetAt DateTime
}

model BalancePolicy {
  id               String                 @id @default(cuid())
  leaveTypeId      String
  leaveType        LeaveType              @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  classificationId String?
  classification   EmployeeClassification? @relation(fields: [classificationId], references: [id], onDelete: Cascade)
  initialCredits   Float                  @default(0)
  accrualRate      Float                  @default(0)
  maxCarryover     Float?
  frequency        AccrualScheme          @default(MONTHLY)
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([leaveTypeId, classificationId])
}
